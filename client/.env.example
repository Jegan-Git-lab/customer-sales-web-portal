# Copy to .env — Vite exposes VITE_* vars to client code. None of these are
# secrets: SPA public client IDs are not confidential by design.

VITE_API_BASE_URL=http://localhost:4000

# --- Entra ID (Staff) app registration ---
VITE_STAFF_CLIENT_ID=33333333-3333-3333-3333-333333333333
VITE_STAFF_TENANT_ID=00000000-0000-0000-0000-000000000000
VITE_STAFF_API_SCOPE=api://insurance-portal-staff/access_as_staff

# --- Entra External ID (Customer) app registration ---
VITE_CUSTOMER_CLIENT_ID=44444444-4444-4444-4444-444444444444
VITE_CUSTOMER_TENANT_NAME=contosoexternal
VITE_CUSTOMER_TENANT_ID=11111111-1111-1111-1111-111111111111
VITE_CUSTOMER_API_SCOPE=api://insurance-portal-customer/access_as_customer

VITE_APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=00000000-0000-0000-0000-000000000000
