# Copy to .env for local dev. NEVER commit the real .env (it is already gitignored).
# In Azure, these become App Service Application Settings — not a .env file.
# Nothing in this file is a secret. The one real secret (dev SP client secret)
# is fetched at runtime from Key Vault — see server/src/dataverse/credential.js

NODE_ENV=development
PORT=4000

# CORS — the deployed Static Web App origin. No wildcards.
ALLOWED_ORIGIN=http://localhost:5173

# --- Entra ID (Staff) ---
STAFF_TENANT_ID=00000000-0000-0000-0000-000000000000
STAFF_API_APP_ID_URI=api://insurance-portal-staff

# --- Entra External ID / B2C (Customer) ---
CUSTOMER_TENANT_NAME=contosoexternal
CUSTOMER_TENANT_ID=11111111-1111-1111-1111-111111111111
CUSTOMER_API_APP_ID_URI=api://insurance-portal-customer

# --- Dataverse ---
DATAVERSE_ENV_URL=https://contoso-portal.crm.dynamics.com
DATAVERSE_API_VERSION=v9.2

# --- Local dev only: identity used to reach Key Vault (az login) ---
KEYVAULT_NAME=contoso-portal-kv
DEV_SP_CLIENT_ID=22222222-2222-2222-2222-222222222222
DEV_TENANT_ID=00000000-0000-0000-0000-000000000000
# The dev SP's *secret* is never here — it's read from Key Vault secret
# name "dataverse-dev-sp-secret" at process start, in memory only.

# --- Azure Communication Services (campaign email) ---
ACS_ENDPOINT=https://contoso-acs.communication.azure.com
ACS_SENDER_ADDRESS=DoNotReply@contoso-verified-domain.azurecomm.net

# --- Application Insights ---
APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=00000000-0000-0000-0000-000000000000
